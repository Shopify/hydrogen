{
  "name": "hydrogen-preview-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:pkgs": "turbo run build --filter='./packages/*'",
    "dev": "turbo run dev",
    "dev:pkgs": "turbo run dev --filter='./packages/*'",
    "dev:rr": "turbo run dev --filter=@shopify/hydrogen-example-react-router...",
    "dev:next": "turbo run dev --filter=@shopify/hydrogen-example-nextjs...",
    "dev:astro": "turbo run dev --filter=@shopify/hydrogen-example-astro...",
    "dev:nuxt": "turbo run dev --filter=@shopify/hydrogen-example-nuxt...",
    "dev:solid": "turbo run dev --filter=@shopify/hydrogen-example-solid-start...",
    "dev:svelte": "turbo run dev --filter=@shopify/hydrogen-example-sveltekit...",
    "dev:hydrogen": "pnpm --dir examples/hydrogen dev",
    "dev:hub": "node scripts/examples-dev.ts",
    "download:standard-types": "node scripts/download-standard-types.ts",
    "examples:secrets:setup": "node scripts/setup-example-secrets-key.ts",
    "examples:secrets:encrypt": "ejson encrypt examples/shared/secrets.ejson",
    "examples:secrets:decrypt": "node scripts/decrypt-example-secrets.ts",
    "benchmark:harness": "node scripts/storefront-benchmark-harness/run-opencode-docker.ts",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --max-warnings=0 packages/ examples/",
    "lint:ci": "oxlint --format github --max-warnings=0 packages/ examples/",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build:pkgs && changeset publish --tag preview",
    "test": "turbo run test",
    "test:benchmark-harness": "tsc -p scripts/storefront-benchmark-harness/tsconfig.json && node --test scripts/storefront-benchmark-harness/*.test.ts",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.8.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "turbo": "^2.9.14",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
