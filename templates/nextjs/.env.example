# Server environment. Copy to `.env` and fill in.
#
# Mode is auto-detected: with a PRIVATE_STOREFRONT_API_TOKEN present the app talks
# to the real store; with none it falls back to the tokenless mock.shop demo (so a
# fresh run or deploy always renders). Set MOCK_SHOP=1 to force the mock explicitly.

# Force the tokenless mock.shop demo (also the default when no token is set).
# MOCK_SHOP=1

# Real store (server-only). Set both for real-store mode.
PUBLIC_STORE_DOMAIN=
PRIVATE_STOREFRONT_API_TOKEN=
