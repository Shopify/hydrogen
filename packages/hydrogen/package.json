{
  "name": "@shopify/hydrogen",
  "version": "0.0.1",
  "description": "Framework-agnostic Shopify storefront SDK and agent skills.",
  "license": "MIT",
  "author": "Shopify",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shopify/hydrogen.git",
    "directory": "packages/hydrogen"
  },
  "bin": {
    "hydrogen": "./dist/cli/index.mjs"
  },
  "files": [
    "README.md",
    "dist",
    "src/graphql/generated",
    "skills"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "development": "./dist/development.d.mts",
        "default": "./dist/index.d.mts"
      },
      "import": {
        "development": "./dist/development.mjs",
        "default": "./dist/index.mjs"
      },
      "default": {
        "development": "./dist/development.mjs",
        "default": "./dist/index.mjs"
      }
    },
    "./storefront-api-types": "./src/graphql/generated/storefront-api-types.d.ts",
    "./storefront.schema.json": "./src/graphql/generated/storefront.schema.json",
    "./skills/*": "./skills/*",
    "./react": {
      "types": {
        "development": "./dist/react/development.d.mts",
        "default": "./dist/react.d.mts"
      },
      "import": {
        "development": "./dist/react/development.mjs",
        "default": "./dist/react.mjs"
      }
    },
    "./cdn": {
      "types": "./dist/cdn/bootstrap.d.mts",
      "import": "./dist/cdn/bootstrap.mjs"
    }
  },
  "publishConfig": {
    "@shopify:registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest --typecheck --run",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "gql.tada": "^1.9.2"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.15.4",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/introspection": "^6.0.0",
    "@graphql-codegen/typescript": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "graphql": "^16.13.2",
    "happy-dom": "^20.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsdown": "^0.21.10",
    "typescript": "catalog:",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
