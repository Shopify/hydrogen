{
  "name": "@shopify/hydrogen-temp",
  "version": "0.0.0",
  "description": "",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "@shopify:registry": "https://registry.npmjs.org"
  },
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/Shopify/hydrogen",
    "directory": "packages/hydrogen-temp"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./storefront-api-types": {
      "types": "./dist/storefront-api-types.d.ts"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./storefront.schema.json": "./storefront.schema.json"
  },
  "scripts": {
    "build": "rimraf dist && tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@shopify/hydrogen-codegen": "workspace:*",
    "@shopify/graphql-client": "1.4.1",
    "type-fest": "^4.33.0"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsup": "^8.4.0",
    "@types/node": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "^6.0.1",
    "vitest": "^3.2.4",
    "graphql": "^16.12.0",
    "@graphql-codegen/cli": "^5.0.4",
    "@graphql-codegen/typescript": "^4.1.3",
    "@graphql-codegen/introspection": "^4.0.3",
    "@graphql-codegen/add": "^5.0.3"
  }
}
