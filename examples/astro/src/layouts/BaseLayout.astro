---
import "../styles/global.css";
import { defaultI18n, shop } from "@shared/config";
import { HEADER_COLLECTIONS_QUERY, normalizeHeaderCollections } from "@shared/header";
import { renderShopifyScriptTags } from "@shopify/hydrogen";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
const { data: headerData } = await Astro.locals.storefrontClient.graphql(HEADER_COLLECTIONS_QUERY);
const headerCollections = normalizeHeaderCollections(headerData?.collections?.nodes);
const shopifyScriptTagsHtml = renderShopifyScriptTags({
  i18n: defaultI18n,
  shop,
}).join("\n");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    />
    <Fragment set:html={shopifyScriptTagsHtml} />
    <title>{title}</title>
  </head>
  <body class="bg-white text-black">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-black focus:px-4 focus:py-2 focus:text-sm focus:font-bold focus:text-white">
      Skip to main content
    </a>
    <Header collections={headerCollections} />
    <slot />
    <Footer />
    <script>
      import { initializeShopifyScripts } from "@shopify/hydrogen";
      import { getAnalytics, AnalyticsEvent } from "../lib/analytics";
      import { routeTemplates } from "../route-templates";

      initializeShopifyScripts({ routes: routeTemplates });

      const analytics = getAnalytics();
      analytics?.publish(AnalyticsEvent.PAGE_VIEWED);
    </script>
  </body>
</html>
