{
  "include": ["**/*", "**/.server/**/*", "**/.client/**/*", ".react-router/types/**/*"],
  "compilerOptions": {
    "plugins": [
      {
        "name": "gql.tada/ts-plugin",
        "schemas": [
          {
            "name": "storefront",
            "schema": "node_modules/@shopify/hydrogen/dist/storefront.schema.json",
            "tadaOutputLocation": "./app/storefront-graphql-env.d.ts"
          },
          {
            "name": "customer-account",
            "schema": "node_modules/@shopify/hydrogen/dist/customer-account.schema.json",
            "tadaOutputLocation": "./app/customer-account-graphql-env.d.ts"
          }
        ],
        "trackFieldUsage": false
      }
    ],
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "@shared/*": ["../shared/*"],
      "~/*": ["./app/*"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  }
}
