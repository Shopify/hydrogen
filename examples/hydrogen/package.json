{
  "name": "hydrogen",
  "version": "2026.4.2",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "shopify hydrogen build --no-lockfile-check",
    "dev": "shopify hydrogen dev",
    "preview": "shopify hydrogen preview --build",
